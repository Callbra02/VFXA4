# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
.utmp/
/VFXA4/[Ll]ibrary/
/VFXA4/[Tt]emp/
/VFXA4/[Oo]bj/
/VFXA4/[Bb]uild/
/VFXA4/[Bb]uilds/
/VFXA4/[Ll]ogs/
/VFXA4/[Uu]ser[Ss]ettings/
/VFXA4/*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
/VFXA4/*.blend1
/VFXA4/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/VFXA4/[Mm]emoryCaptures/

# Recordings can get excessive in size
/VFXA4/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /VFXA4/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/VFXA4/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
/VFXA4/*.DotSettings.user

# Visual Studio cache directory
/VFXA4/.vs/

# Gradle cache directory
/VFXA4/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
/VFXA4/.consulo/
/VFXA4/*.csproj
/VFXA4/*.unityproj
/VFXA4/*.sln
/VFXA4/*.suo
/VFXA4/*.tmp
/VFXA4/*.user
/VFXA4/*.userprefs
/VFXA4/*.pidb
/VFXA4/*.booproj
/VFXA4/*.svd
/VFXA4/*.pdb
/VFXA4/*.mdb
/VFXA4/*.opendb
/VFXA4/*.VC.db

# Unity3D generated meta files
/VFXA4/*.pidb.meta
/VFXA4/*.pdb.meta
/VFXA4/*.mdb.meta

# Unity3D generated file on crash reports
/VFXA4/sysinfo.txt

# Mono auto generated files
/VFXA4/mono_crash.*

# Builds
/VFXA4/*.apk
/VFXA4/*.aab
/VFXA4/*.unitypackage
/VFXA4/*.unitypackage.meta
/VFXA4/*.app

# Crashlytics generated file
/VFXA4/crashlytics-build.properties

# TestRunner generated files
/VFXA4/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/VFXA4/ServerData
/VFXA4/[Aa]ssets/StreamingAssets/aa*
/VFXA4/[Aa]ssets/AddressableAssetsData/link.xml*
/VFXA4/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/VFXA4/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/VFXA4/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/VFXA4/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/VFXA4/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/VFXA4/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/VFXA4/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
